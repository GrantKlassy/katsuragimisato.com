---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>katsuragimisato.com</title>
  </head>
  <body class="m-0 h-screen w-screen overflow-hidden bg-black text-white">
    <canvas id="misato" class="block h-full w-full"></canvas>
    <div
      class="pointer-events-none absolute inset-0 flex flex-col items-center justify-end p-12 font-mono"
    >
      <h1
        class="text-5xl font-bold tracking-[0.3em] drop-shadow-lg md:text-7xl"
      >
        KATSURAGI MISATO
      </h1>
      <p class="mt-3 text-sm tracking-[0.5em] text-purple-200/80">
        NERV OPERATIONS DIRECTOR
      </p>
    </div>

    <script>
      import { mountMisatoScene } from "../lib/misato-scene";
      const canvas = document.getElementById("misato") as HTMLCanvasElement;
      if (canvas) mountMisatoScene(canvas);
    </script>
  </body>
</html>
