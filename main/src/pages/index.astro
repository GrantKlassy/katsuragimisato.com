---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>katsuragimisato.com</title>
  </head>
  <body class="m-0 h-screen w-screen overflow-hidden bg-black text-white">
    <canvas id="webgl" class="block h-full w-full"></canvas>
    <div
      class="pointer-events-none absolute inset-0 flex flex-col items-center justify-center gap-8 p-12 font-mono"
    >
      <h1
        class="text-5xl font-bold tracking-[0.3em] drop-shadow-lg md:text-7xl"
      >
        KATSURAGI MISATO
      </h1>
      <nav
        class="pointer-events-auto flex flex-col items-center gap-2 text-lg tracking-widest md:text-xl"
      >
        <a
          href="https://wiki.evageeks.org/Misato_Katsuragi"
          target="_blank"
          rel="noopener noreferrer"
          class="underline-offset-4 drop-shadow-lg hover:underline"
        >
          Misato Katsuragi
        </a>
        <a
          href="https://wiki.evageeks.org/Misato%27s_Car"
          target="_blank"
          rel="noopener noreferrer"
          class="underline-offset-4 drop-shadow-lg hover:underline"
        >
          Misato's Car
        </a>
        <a
          href="https://wiki.evageeks.org/Dr._Katsuragi"
          target="_blank"
          rel="noopener noreferrer"
          class="underline-offset-4 drop-shadow-lg hover:underline"
        >
          Misato's Father
        </a>
        <a
          href="https://wiki.evageeks.org/Misato%27s_Car"
          target="_blank"
          rel="noopener noreferrer"
          class="underline-offset-4 drop-shadow-lg hover:underline"
        >
          Misato's Car
        </a>
      </nav>
    </div>

    <script>
      import { mountTestScene } from "../lib/test-scene";
      const canvas = document.getElementById("webgl") as HTMLCanvasElement;
      if (canvas) mountTestScene(canvas);
    </script>
  </body>
</html>
