---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>katsuragimisato.com</title>
  </head>
  <body class="m-0 h-screen w-screen overflow-hidden bg-black text-white">
    <canvas id="webgl" class="block h-full w-full"></canvas>
    <div
      class="pointer-events-none absolute inset-0 flex flex-col items-center justify-center p-12 font-mono"
    >
      <a
        href="https://wiki.evageeks.org/Misato_Katsuragi"
        target="_blank"
        rel="noopener noreferrer"
        class="pointer-events-auto"
      >
        <h1
          class="text-5xl font-bold tracking-[0.3em] drop-shadow-lg md:text-7xl"
        >
          KATSURAGI MISATO
        </h1>
      </a>
    </div>

    <script>
      import { mountTestScene } from "../lib/test-scene";
      const canvas = document.getElementById("webgl") as HTMLCanvasElement;
      if (canvas) mountTestScene(canvas);
    </script>
  </body>
</html>
